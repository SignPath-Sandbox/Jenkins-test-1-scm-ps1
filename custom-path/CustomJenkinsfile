pipeline {
    agent any

    stages {
        stage('Checkout PowerShell file') {
            steps {
                sh '''
                    set -eu

                    mkdir -p build-output

                    rm -rf temp-script-repo
                    git clone --depth 1 --branch branchA https://github.com/SignPath-Sandbox/Jenkins-test-3-scm-ps1.git temp-script-repo

                    cp temp-script-repo/script.ps1 build-output/script.ps1

                    ls -lh build-output
                    cat build-output/script.ps1
                '''
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'build-output/**', fingerprint: true
        }
    }
}
