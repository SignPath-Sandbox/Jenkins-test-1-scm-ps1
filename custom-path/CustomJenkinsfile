pipeline {
    agent any

    stages {

        stage('Wait 60 seconds') {
            steps {
                sleep time: 60, unit: 'SECONDS'
            }
        }

        stage('Create PowerShell file') {
            steps {
                sh '''
                    set -eu

                    mkdir -p build-output

                    COMMIT_SHA="$(git rev-parse HEAD 2>/dev/null || echo '')"
                    SHORT_COMMIT_SHA="$(git rev-parse --short HEAD 2>/dev/null || echo '')"
                    BRANCH_NAME_GIT="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '')"
                    REMOTE_URL="$(git config --get remote.origin.url 2>/dev/null || echo '')"
                    COMMIT_AUTHOR="$(git log -1 --pretty=format:'%an <%ae>' 2>/dev/null || echo '')"
                    COMMIT_MESSAGE="$(git log -1 --pretty=format:'%s' 2>/dev/null || echo '')"
                    COMMIT_DATE="$(git log -1 --pretty=format:'%cI' 2>/dev/null || echo '')"

                    cat > build-output/script.ps1 <<EOF

Write-Host "Jenkins Build Number: ${BUILD_NUMBER:-}"
Write-Host "Jenkins Build ID: ${BUILD_ID:-}"
Write-Host "Jenkins Build Tag: ${BUILD_TAG:-}"
Write-Host "Jenkins Job Name: ${JOB_NAME:-}"
Write-Host "Jenkins Job Base Name: ${JOB_BASE_NAME:-}"
Write-Host "Jenkins Build URL: ${BUILD_URL:-}"
Write-Host "Jenkins Workspace: ${WORKSPACE:-}"
Write-Host "Jenkins Node Name: ${NODE_NAME:-}"
Write-Host "Jenkins Executor Number: ${EXECUTOR_NUMBER:-}"

Write-Host "Git Branch Jenkins: ${BRANCH_NAME:-}"
Write-Host "Git Branch Local: $BRANCH_NAME_GIT"
Write-Host "Git Commit SHA1 Jenkins: ${GIT_COMMIT:-}"
Write-Host "Git Commit SHA1 Actual: $COMMIT_SHA"
Write-Host "Git Short Commit SHA1: $SHORT_COMMIT_SHA"
Write-Host "Git Previous Commit: ${GIT_PREVIOUS_COMMIT:-}"
Write-Host "Git Previous Successful Commit: ${GIT_PREVIOUS_SUCCESSFUL_COMMIT:-}"
Write-Host "Git URL Jenkins: ${GIT_URL:-}"
Write-Host "Git Remote URL Actual: $REMOTE_URL"
Write-Host "Git Author: $COMMIT_AUTHOR"
Write-Host "Git Commit Date: $COMMIT_DATE"
Write-Host "Git Commit Message: $COMMIT_MESSAGE"

Write-Host "GitHub Repository: ${GITHUB_REPOSITORY:-}"
Write-Host "GitHub Ref: ${GITHUB_REF:-}"
Write-Host "GitHub SHA: ${GITHUB_SHA:-}"
Write-Host "GitHub Actor: ${GITHUB_ACTOR:-}"
EOF

                    ls -lh build-output
                    cat build-output/script.ps1
                '''
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'build-output/**', fingerprint: true
        }
    }
}
